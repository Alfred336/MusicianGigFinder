// ============================================================
//  Firebase Storage Rules — Musician Gig Finder
//  Deploy via: firebase deploy --only storage
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile images: authenticated users can upload their own,
    // anyone can read (for public profile display)
    match /profile_images/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Sample media (audio/video) — musician uploads only
    match /sample_media/{mediaId} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
